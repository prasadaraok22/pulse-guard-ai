# Pulse Guard AI — example environment configuration
# Copy to `.env` and adjust. All variables use the PULSE_ prefix.
# Values shown are the built-in defaults (see app/config.py).

# --- Database ---------------------------------------------------------------
# SQLite (default, zero-config):
PULSE_DATABASE_URL=sqlite:///./pulse_guard.db
# Postgres (uncomment to use; matches docker-compose service "db"):
# PULSE_DATABASE_URL=postgresql+psycopg2://pulse:pulse@localhost:5432/pulseguard

# --- Anomaly detection tuning ----------------------------------------------
PULSE_WINDOW_SIZE=12            # rolling window length (buckets)
PULSE_BUCKET_SECONDS=60         # time-bucket size (seconds)
PULSE_ZSCORE_THRESHOLD=3.0      # z-score above which a spike is flagged
PULSE_EWMA_ALPHA=0.3            # EWMA baseline smoothing factor
PULSE_MIN_EVENTS_FOR_ALERT=5    # minimum errors in a bucket before alerting

# --- Webhook alerting -------------------------------------------------------
# Leave PULSE_WEBHOOK_URL empty to record alerts to a local sink (offline demo).
PULSE_WEBHOOK_URL=
# Flavour is auto-detected from the URL; override with slack | discord | generic.
PULSE_WEBHOOK_TYPE=auto
PULSE_WEBHOOK_TIMEOUT=5.0
# Examples:
# PULSE_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX
# PULSE_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefghijklmnop

# --- Continuous log polling (background scheduler) --------------------------
PULSE_POLL_ENABLED=false        # auto-start the poller on app startup
PULSE_POLL_DIRECTORY=./ingest_watch
PULSE_POLL_GLOB=*.log
PULSE_POLL_INTERVAL_SECONDS=30

# --- LLM enrichment (OPT-IN, off by default) --------------------------------
# When enabled, each detected spike is annotated with a root-cause hypothesis,
# remediation, a short label, and a business-impact rating. Uses any
# OpenAI-compatible /chat/completions endpoint (OpenAI, Azure, OpenRouter,
# local ollama/llama.cpp proxy). The statistical engine remains the sole
# trigger — the LLM only annotates. Fail-safe: errors never break ingestion.
PULSE_LLM_ENABLED=false
PULSE_LLM_API_KEY=
PULSE_LLM_BASE_URL=https://api.openai.com/v1
PULSE_LLM_MODEL=gpt-4o-mini
PULSE_LLM_TIMEOUT=20.0
PULSE_LLM_MAX_MESSAGES=12        # top error messages sampled per anomaly
PULSE_LLM_SUMMARIZE=true         # root-cause + remediation
PULSE_LLM_CLASSIFY=true          # short error label
PULSE_LLM_TRIAGE=true            # business-impact rating
# Cost controls:
PULSE_LLM_MIN_SEVERITY=critical  # auto-enrich only >= this (info|warning|critical)
PULSE_LLM_CACHE_ENABLED=true     # reuse results by error-signature (no repeat calls)
PULSE_LLM_CACHE_MAX=512          # max cached signatures (LRU eviction)

# --- App --------------------------------------------------------------------
PULSE_APP_NAME=Pulse Guard AI

# --- Testing (optional) -----------------------------------------------------
# Point the pytest suite at a specific DB (e.g. Postgres in CI):
# PULSE_TEST_DATABASE_URL=postgresql+psycopg2://pulse:pulse@localhost:5432/pulseguard

